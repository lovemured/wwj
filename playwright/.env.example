# CRM PC端测试配置
CRM_BASE_URL=https://lxcrm-staging.weiwenjia.com
CRM_USERNAME=your_username
CRM_PASSWORD=your_password

# Playwright Android WebView 测试配置
APP_PACKAGE=com.lixiaoyun.aike
WEBVIEW_CDP_ENDPOINT=http://localhost:9222
TEST_USERNAME=your_username
TEST_PASSWORD=your_password
DEVICE_TIMEOUT=30000

# ========================================
# Midscene AI 模型配置（选择其中一种）
# ========================================

# 方案 1：使用 OpenAI GPT-4V（推荐）
# MIDSCENE_MODEL_API_KEY=sk-your_openai_api_key
# MIDSCENE_MODEL_NAME=gpt-4o

# 方案 2：使用火山引擎 UI-TARS
# MIDSCENE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# MIDSCENE_MODEL_API_KEY=your_volcano_api_key
# MIDSCENE_MODEL_NAME=ep-2025-your-endpoint-id
# MIDSCENE_MODEL_FAMILY=vlm-ui-tars-doubao-1.5

# 方案 3：使用其他兼容 OpenAI API 的服务
# MIDSCENE_MODEL_API_KEY=your_api_key
# MIDSCENE_MODEL_BASE_URL=https://your-service.com/v1
# MIDSCENE_MODEL_NAME=gpt-4-vision-preview

# ⚠️ 重要：你必须配置其中一个模型才能运行测试！
# 请取消注释对应的配置行并填入你的 API Key
